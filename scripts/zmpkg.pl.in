use strict;
use bytes;

# ==========================================================================
#
# Don't change anything below here
#
# ==========================================================================

@EXTRA_PERL_LIB@
use ZoneMinder;
use POSIX;
use autouse 'Pod::Usage'=>qw(pod2usage);

# Detaint our environment
$ENV{PATH}  = '/bin:/usr/bin:/usr/local/bin';
$ENV{SHELL} = '/bin/sh' if exists $ENV{SHELL};

logInit();

my $command = $ARGV[0] || '';

if ( $command eq 'version' ) {
  print ZoneMinder::Base::ZM_VERSION . "\n";
  exit(0);
}

if ( !$command ) {
  pod2usage(-exitstatus => -1);
}

# Standard commands get detainted
if ( $command =~ /^(start|stop|restart|status|logrot)$/ ) {
  $command = $1;
} else {
  # Might be a named state - detaint and delegate to zmdc.pl
  if ( $command =~ /^([\w.-]+)$/ ) {
    $command = $1;
  } else {
    print(STDERR "Invalid command '$command'\n");
    pod2usage(-exitstatus => -1);
  }

  # Ensure server is running, then apply state
  runCommand('zmdc.pl startup');
  runCommand("zmdc.pl state $command");
  exit(0);
}

# Check if we are running systemd and if we have been called by the system
if ( $command =~ /^(?:start|stop|restart)$/ ) {
  if ( systemdRunning() && !calledBysystem() ) {
    qx(@BINDIR@/zmsystemctl.pl $command);
    exit(0);
  }
}

if ( $command eq 'status' ) {
  my $status = runCommand('zmdc.pl check');
  print(STDOUT $status . "\n");
  exit(0);
}

if ( $command eq 'logrot' ) {
  runCommand('zmdc.pl logrot');
  exit(0);
}

my $retval = 0;

if ( $command =~ /^(?:stop|restart)$/ ) {
  my $status = runCommand('zmdc.pl check');
  Debug("zmdc.pl check = $status");

  if ( $status eq 'running' ) {
    runCommand('zmdc.pl shutdown');
  } else {
    $retval = 1;
  }
}

if ( $command =~ /^(?:start|restart)$/ ) {
  my $status = runCommand('zmdc.pl check');
  Debug("zmdc.pl check = $status");

  if ( $status eq 'stopped' ) {
    runCommand('zmdc.pl startup');
  } else {
    $retval = 1;
  }
}

exit($retval);

sub systemdRunning {
  my $output = qx(ps -o comm="" -p 1);
  return scalar ( $output =~ /systemd/ );
}

sub calledBysystem {
  my $ppid = getppid();
  my $output = qx(ps -o comm="" -p $ppid);
  return ($output =~ /^(?:systemd|init)$/);
}

1;
__END__

=head1 NAME

zmpkg.pl - ZoneMinder Package Control Script

=head1 SYNOPSIS

zmpkg.pl {start|stop|restart|status|logrot|<state_name>|version}

=head1 DESCRIPTION

This script controls the ZoneMinder package. It delegates to zmdc.pl
which handles all daemon management, orchestration, and monitoring.

=cut
